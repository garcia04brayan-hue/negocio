function openModal(id) {
  const a = articles[id];
  if (!a) return;
  document.getElementById('m-tag').textContent = a.tag;
  document.getElementById('m-title').textContent = a.title;
  document.getElementById('m-meta').textContent = a.meta;
  document.getElementById('m-body').innerHTML = a.body;
  document.getElementById('modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function filterTag(btn, tag) {
  document.querySelectorAll('.ftag').forEach(t => t.classList.remove('on'));
  btn.classList.add('on');
  const cards = document.querySelectorAll('#articles-grid .article-card');
  let count = 1; // featured always shown
  cards.forEach(card => {
    if (tag === 'todos' || (card.dataset.tags || '').includes(tag)) {
      card.style.display = '';
      count++;
    } else {
      card.style.display = 'none';
    }
  });
  document.getElementById('art-count').textContent = `Mostrando ${count} artículo${count !== 1 ? 's' : ''}`;
}

function filterArticles(q) {
  q = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#articles-grid .article-card');
  let count = 1;
  cards.forEach(card => {
    const text = card.innerText.toLowerCase();
    if (!q || text.includes(q)) { card.style.display = ''; count++; }
    else { card.style.display = 'none'; }
  });
  document.getElementById('art-count').textContent = `Mostrando ${count} artículo${count !== 1 ? 's' : ''}`;
}
